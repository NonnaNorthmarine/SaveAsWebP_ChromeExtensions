{
  "manifest_version": 3,
  "name": "WebPとして保存",
  "version": "1.0",
  "description": "画像を右クリックしてWebP形式に変換し保存します。",
  "permissions": [
    "contextMenus",
    "downloads",
    "offscreen",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebP画質の設定"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
